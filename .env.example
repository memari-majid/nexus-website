# Public site URL (canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://nexusaisolution.net

# Try Our AI — public URLs for linked chatbots (full URL including path, e.g. financial assistant app)
NEXT_PUBLIC_AI_CPA_URL=
NEXT_PUBLIC_AI_TA_URL=

# OpenAI — required for /api/chat (site assistant)
OPENAI_API_KEY=
# Optional override (default: gpt-5.4-mini)
OPENAI_MODEL=gpt-5.4-mini

# Optional: model for contact classification (default: gpt-4o-mini)
CONTACT_CLASSIFY_MODEL=gpt-4o-mini

# Email — optional; without RESEND_API_KEY, contact form logs server-side only
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. Nexus AI <contact@yourdomain.com>
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=info@nexusaisolution.net
