# Public site URL (canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://nexusaisolution.net

# Try Our AI — public URLs for linked chatbots (full URL including path, e.g. financial assistant app)
NEXT_PUBLIC_AI_CPA_URL=
NEXT_PUBLIC_AI_TA_URL=

# ─── Vercel AI Gateway ───
# Auth is automatic on Vercel deployments via OIDC.
# For local dev: run `vercel link` then `vercel env pull .env.local` to provision VERCEL_OIDC_TOKEN (~24h).
# Optional fallback for non-Vercel environments / CI:
# AI_GATEWAY_API_KEY=

# Optional model overrides — must use `provider/model` slug routed via AI Gateway.
# Defaults: openai/gpt-oss-20b for both. See https://vercel.com/docs/ai-gateway for full list.
AI_CHAT_MODEL=openai/gpt-oss-20b
CONTACT_CLASSIFY_MODEL=openai/gpt-oss-20b

# Email — optional; without RESEND_API_KEY, contact form logs server-side only
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. Nexus AI <contact@yourdomain.com>
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=info@nexusaisolution.net
